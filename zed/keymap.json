// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Editor",
    "bindings": {
      "f2": "editor::Rename",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "shift shift": "file_finder::Toggle",
    },
  },
  {
    "context": "vim_mode == normal",
    "bindings": {
      "space q": "pane::CloseActiveItem",
      "g e": "editor::GoToDiagnostic",
      "g E": "editor::GoToPreviousDiagnostic",
      "g c": "editor::ToggleCodeActions",
      "Y": "vim::YankToEndOfLine",
      "S": "vim::ChangeToEndOfLine",
      "J": ["workspace::SendKeystrokes", "m z J ` z"],
      "space w n": "workspace::NewFileSplitHorizontal",
      "space w v": "workspace::NewFileSplitVertical",
      "space h": "workspace::ActivatePaneLeft",
      "space j": "workspace::ActivatePaneDown",
      "space k": "workspace::ActivatePaneUp",
      "space l": "workspace::ActivatePaneRight",
      "space f": [
        "task::Spawn",
        { "task_name": "Television File Finder", "reveal_target": "center" },
      ],
      "ctrl-n": "vim::ToggleProjectPanelFocus",
    },
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "ctrl-n": "workspace::ToggleRightDock",
    },
  },
  {
    "context": "vim_mode == visual",
    "bindings": {
      "<": ["workspace::SendKeystrokes", "< g v"],
      ">": ["workspace::SendKeystrokes", "> g v"],
    },
  },
  {
    "context": "VimControl || vim_mode == insert",
    "bindings": {
      "ctrl-j": "editor::MoveLineDown",
      "ctrl-k": "editor::MoveLineUp",
    },
  },
]
